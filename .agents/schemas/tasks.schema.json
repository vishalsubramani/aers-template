{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AERS Task Graph",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "feature_id",
    "tasks"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "feature_id": {
      "type": "string"
    },
    "tasks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "title",
          "role",
          "depends_on",
          "write_scope",
          "acceptance",
          "commands",
          "budget"
        ],
        "properties": {
          "id": {
            "pattern": "^T-[0-9]{3}$"
          },
          "title": {
            "type": "string"
          },
          "role": {
            "enum": [
              "explorer",
              "architect",
              "implementer",
              "test_author",
              "reviewer",
              "security",
              "sre",
              "documentation"
            ]
          },
          "depends_on": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "write_scope": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "acceptance": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "commands": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "name",
                "argv",
                "timeout_seconds"
              ],
              "properties": {
                "name": {
                  "type": "string"
                },
                "argv": {
                  "type": "array",
                  "minItems": 1,
                  "items": {
                    "type": "string"
                  }
                },
                "timeout_seconds": {
                  "type": "integer",
                  "minimum": 1
                },
                "network": {
                  "enum": [
                    "deny",
                    "allowlisted"
                  ]
                }
              }
            }
          },
          "budget": {
            "type": "object",
            "required": [
              "max_attempts",
              "max_files",
              "max_lines",
              "max_seconds"
            ],
            "properties": {
              "max_attempts": {
                "type": "integer",
                "minimum": 1
              },
              "max_files": {
                "type": "integer",
                "minimum": 0
              },
              "max_lines": {
                "type": "integer",
                "minimum": 0
              },
              "max_seconds": {
                "type": "integer",
                "minimum": 1
              }
            }
          },
          "notes": {
            "type": "string"
          },
          "differential": {
            "type": "object",
            "required": [
              "argv_template"
            ],
            "additionalProperties": false,
            "properties": {
              "argv_template": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "string"
                }
              },
              "timeout_seconds": {
                "type": "integer",
                "minimum": 1
              }
            }
          }
        }
      }
    }
  }
}
