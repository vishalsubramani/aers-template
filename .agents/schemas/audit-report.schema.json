{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "candidate_sha",
    "verdict",
    "findings",
    "evidence_hash"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "run_id": {
      "type": "string"
    },
    "candidate_sha": {
      "type": "string"
    },
    "verdict": {
      "enum": [
        "pass",
        "fail",
        "needs_review"
      ]
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "severity",
          "code",
          "message"
        ],
        "properties": {
          "severity": {
            "enum": [
              "info",
              "low",
              "medium",
              "high",
              "critical"
            ]
          },
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "path": {
            "type": "string"
          }
        }
      }
    },
    "evidence_hash": {
      "type": "string"
    }
  }
}
