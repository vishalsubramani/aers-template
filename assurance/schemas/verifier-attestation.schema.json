{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AERS verifier attestation (DSSE envelope over an in-toto statement)",
  "type": "object",
  "additionalProperties": false,
  "required": ["payloadType", "payload", "signatures"],
  "properties": {
    "payloadType": {"const": "application/vnd.aers.verification+json"},
    "payload": {"type": "string", "description": "base64 of the canonical in-toto statement"},
    "signatures": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["keyid", "sig"],
        "properties": {"keyid": {"type": "string"}, "sig": {"type": "string"}}
      }
    }
  },
  "$defs": {
    "statement": {
      "type": "object",
      "required": ["_type", "predicateType", "subject", "predicate"],
      "properties": {
        "_type": {"const": "https://in-toto.io/Statement/v1"},
        "predicateType": {"const": "https://aers.dev/attestation/verification/v1"},
        "subject": {"type": "array"},
        "predicate": {
          "type": "object",
          "required": [
            "verdict", "handoff_digest", "candidate_digest", "policy_digest",
            "evidence_digest", "verifier_identity", "trust_domain",
            "reason_codes", "timestamp", "expires_at", "nonce"
          ],
          "properties": {
            "verdict": {"enum": ["VERIFIED", "REJECTED", "INFRASTRUCTURE_ERROR"]},
            "trust_domain": {"type": "string", "description": "offline-demo for demo-signed; a real domain for production"}
          }
        }
      }
    }
  }
}
